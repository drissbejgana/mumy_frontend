# Backend API URL — set at BUILD time (baked in by Vite)
# Example: https://your-railway-app.railway.app
VITE_API_URL="https://your-railway-app.railway.app"

# Google OAuth Client ID (from Google Cloud Console)
# Must be the same client ID used in backend ADMIN_EMAIL checks
VITE_GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"

# Microsoft OAuth Client ID (from Azure Portal > App registrations)
# Leave blank to hide the "Sign in with Microsoft" button
VITE_MICROSOFT_CLIENT_ID=""
